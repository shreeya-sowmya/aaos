<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF121212"
    android:orientation="horizontal"
    android:paddingTop="80dp" 
    android:paddingBottom="90dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#11FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="10dp">
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/battery_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="--%" android:textSize="18sp" android:textColor="#00FF00" android:textStyle="bold" android:gravity="center" android:shadowColor="#000000" android:shadowRadius="1"/>
                <TextView android:id="@+id/drive_time_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="0m" android:textSize="18sp" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:shadowColor="#000000" android:shadowRadius="1"/>
                <TextView android:id="@+id/evict_count_text" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Evict:0" android:textSize="14sp" android:textColor="#E24B4A" android:textStyle="bold" android:gravity="center" android:shadowColor="#000000" android:shadowRadius="1"/>
            </LinearLayout>

            <ProgressBar android:id="@+id/battery_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="4dp" android:layout_marginTop="4dp" android:max="100" android:progress="100"/>
            <TextView android:id="@+id/status_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Status: Active" android:textSize="14sp" android:textColor="#FFFFFF" android:maxLines="1" android:textStyle="bold|italic"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/action_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">
            <Button android:id="@+id/btn_start_simulation" android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1" android:text="START" android:textSize="14sp" android:backgroundTint="#185FA5"/>
            <Button android:id="@+id/btn_drive_test" android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1.5" android:text="DRIVE" android:textSize="14sp" android:textStyle="bold" android:backgroundTint="#1D9E75" android:layout_marginStart="6dp"/>
        </LinearLayout>

        <TextView 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:text="LRU CACHE" 
            android:textSize="15sp" 
            android:textColor="#FFFFFF" 
            android:textStyle="bold"
            android:alpha="1.0"
            android:layout_marginBottom="6dp"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"/>

        <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:scrollbars="vertical" android:fadeScrollbars="false">
            <LinearLayout android:id="@+id/lru_panel" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
        </ScrollView>

        <!-- Driver Preference Panel — live accept/reject ratios, updated on every alert interaction -->
        <TextView
            android:id="@+id/pref_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textSize="11sp"
            android:textColor="#78909C"
            android:fontFamily="monospace"
            android:background="#0DFFFFFF"
            android:text="Prefs: no data yet"
            android:maxLines="1"
            android:ellipsize="end"/>

        <LinearLayout 
            android:id="@+id/alert_card" 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content" 
            android:minHeight="140dp" 
            android:orientation="vertical" 
            android:background="#DD333333" 
            android:padding="12dp" 
            android:layout_marginTop="8dp" 
            android:visibility="gone">
            
            <TextView android:id="@+id/alert_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp" android:textStyle="bold" android:textColor="#FFEB3B"/>
            <TextView android:id="@+id/alert_body" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="14sp" android:textColor="#FFFFFF" android:layout_marginVertical="8dp" android:lineSpacingExtra="2dp"/>
            
            <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:orientation="horizontal" android:layout_marginTop="4dp">
                <Button android:id="@+id/btn_alert_accept" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="OK" android:textStyle="bold" android:backgroundTint="#1D9E75"/>
                <Button android:id="@+id/btn_alert_defer" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="10m" android:backgroundTint="#BA7517" android:layout_marginHorizontal="6dp"/>
                <Button android:id="@+id/btn_alert_dismiss" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="0.6" android:text="X" android:backgroundTint="#B71C1C"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.8"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simulation Log"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="40dp" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <Button android:id="@+id/btn_copy_log" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="COPY" android:textSize="11sp" android:backgroundTint="#455A64"/>
            <Button android:id="@+id/btn_clear_log" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="CLR" android:textSize="11sp" android:backgroundTint="#2A2A28" android:layout_marginStart="6dp"/>
            <Button android:id="@+id/btn_stop_simulation" android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1.5" android:text="STOP" android:textSize="14sp" android:textStyle="bold" android:backgroundTint="#1D9E75" android:layout_marginStart="6dp"/>
        </LinearLayout>

        <ScrollView android:id="@+id/log_scroll" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0AFFFFFF" android:scrollbars="vertical" android:fadeScrollbars="false">
            <TextView android:id="@+id/log_console" 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                android:padding="8dp" 
                android:textSize="14sp" 
                android:textColor="#00FF00" 
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"/>
        </ScrollView>
    </LinearLayout>
</LinearLayout>